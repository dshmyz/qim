{
  "name": "qim",
  "version": "1.0.0",
  "description": "即时通讯 UI 组件库",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "typecheck": "vue-tsc --noEmit",
    "electron:dev": "electron --no-sandbox .",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "com.qim.app",
    "productName": "QIM",
    "electronVersion": "28.0.0",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "electron-dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "axios": "^1.15.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.13.7",
    "pinia": "^3.0.4",
    "vue": "^3.4.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}
