{
  "name": "qim",
  "author": "QIM Team <huangqun@buaa.edu.cn>",
  "version": "1.0.0",
  "description": "即时通讯 UI 组件库",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron --no-sandbox .\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "electron:build": "electron-builder",
    "electron:build:win7": "electron-builder --win --x64 -c electron-builder-win7.yml",
    "electron:build:win10": "electron-builder --win --x64 -c.win10",
    "electron:build:linux": "electron-builder --linux",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:all": "bash scripts/build-all.sh",
    "icon:generate": "node electron/icons/generate-all-icons.js"
  },
  "build": {
    "appId": "com.qim.app",
    "productName": "青雀 QIM",
    "electronVersion": "33.0.0",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "electron-dist",
      "buildResources": "electron/icons"
    },
    "extraResources": [
      {
        "from": "electron/install-update-linux.sh",
        "to": "install-update-linux.sh"
      },
      {
        "from": "electron/qim-update.sudoers",
        "to": "qim-update.sudoers"
      }
    ],
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "electron/icons/icon_512x512.png",
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "afterInstall": "electron/after-install-linux.sh",
      "beforeRemove": "electron/before-remove-linux.sh"
    },
    "mac": {
      "icon": "electron/icons/QIM.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "QIM-${version}.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "${env.QIM_UPDATE_URL}/api/v1/updates/win10/",
      "channel": "latest"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "@types/spark-md5": "^3.0.5",
    "axios": "^1.15.0",
    "dompurify": "^3.4.1",
    "electron-updater": "^6.8.3",
    "lunar-javascript": "^1.7.7",
    "marked": "^18.0.2",
    "pdfjs-dist": "^5.7.284",
    "pinia": "^3.0.4",
    "spark-md5": "^3.0.2",
    "vue": "^3.4.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.5.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "terser": "^5.47.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.21",
    "wait-on": "^9.0.10"
  }
}
