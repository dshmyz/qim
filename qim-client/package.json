{
  "name": "qim",
  "author": "QIM Team <huangqun@buaa.edu.cn>",
  "version": "1.0.0",
  "description": "即时通讯 UI 组件库",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "electron:dev": "electron --no-sandbox .",
    "electron:build": "electron-builder",
    "electron:build:win7": "electron-builder --win --x64 -c.win7",
    "electron:build:win10": "electron-builder --win --x64 -c.win10",
    "electron:build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.qim.app",
    "productName": "QIM",
    "author": {
      "name": "QIM Team",
      "email": "huangqun@buaa.edu.cn"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "electron-dist"
    },
    "win7": {
      "target": [
        {
          "name": "nsis",
          "artifactName": "${productName}-Setup-${version}-Win7.${ext}"
        },
        {
          "name": "portable",
          "artifactName": "${productName}-${version}-Win7.${ext}"
        }
      ],
      "electronVersion": "22.3.27"
    },
    "win10": {
      "target": [
        {
          "name": "nsis",
          "artifactName": "${productName}-Setup-${version}-Win10.${ext}"
        },
        {
          "name": "portable",
          "artifactName": "${productName}-${version}-Win10.${ext}"
        }
      ],
      "electronVersion": "41.2.0"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://update.example.com/"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.1",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.2",
    "pinia": "^3.0.4",
    "vue": "^3.4.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.5.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.21"
  }
}
