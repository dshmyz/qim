}

// 群成员搜索
const memberSearchQuery = ref('')
const showMemberSearch = ref(false)
const toggleMemberSearch = () => {
  showMemberSearch.value = !showMemberSearch.value
  // 如果显示搜索框，清空搜索内容并聚焦
  if (showMemberSearch.value) {
    memberSearchQuery.value = ''
    // 在下一个DOM更新周期聚焦输入框
    nextTick(() => {
