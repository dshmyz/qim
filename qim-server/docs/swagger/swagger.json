    "definitions": {
        "ai.Message": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                }
            }
        },
        "handler.AIResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "handler.CommandGenerationRequest": {
            "type": "object",
            "required": [
                "description"
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "format": {
                    "type": "string"
                },
                "platform": {
                    "type": "string"
                }
            }
        },
        "handler.ExecuteToolRequest": {
            "type": "object",
            "required": [
                "tool_name"
            ],
            "properties": {
                "parameters": {
                    "type": "object",
                    "additionalProperties": true
                },
                "tool_name": {
                    "type": "string"
                }
            }
        },
        "handler.GetCompletionRequest": {
            "type": "object",
            "required": [
                "messages"
            ],
            "properties": {
                "messages": {
                    "type": "array",
                    "items": {
